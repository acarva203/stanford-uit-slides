{
  "template_name": "castro",
  "slide_size": {
    "width": "10in",
    "height": "5.625in",
    "emu_width": 9144000,
    "emu_height": 5143500
  },
  "design_principles": {
    "note": "Castro is a bold, high-impact template. Full-bleed dark backgrounds, uppercase typography, and yellow accent elements define the aesthetic. Every slide should command attention.",
    "min_margin": "48px",
    "preferred_alignment": "left"
  },
  "layouts": {
    "title_slide": {
      "description": "Dark full-bleed title with bold uppercase headline and yellow accent bar",
      "background": "#0D0D0D",
      "elements": {
        "yellow_bar": {
          "type": "rectangle",
          "x": "48px",
          "y": "36%",
          "width": "80px",
          "height": "6px",
          "fill": "#FEC51D"
        },
        "title": {
          "x": "48px",
          "y": "40%",
          "width": "75%",
          "font_size": "52pt",
          "font_family": "Source Sans 3",
          "font_weight": "900",
          "color": "#FFFFFF",
          "text_transform": "uppercase",
          "letter_spacing": "0.02em"
        },
        "subtitle": {
          "x": "48px",
          "y": "62%",
          "width": "60%",
          "font_size": "20pt",
          "font_family": "Source Sans 3",
          "color": "#CCCCCC"
        },
        "date_or_byline": {
          "x": "48px",
          "y": "73%",
          "width": "50%",
          "font_size": "13pt",
          "font_family": "Source Sans 3",
          "color": "#8A8A8A"
        }
      }
    },
    "section_divider": {
      "description": "Full-bleed color break with large section number and title",
      "background": "#FEC51D",
      "elements": {
        "section_number": {
          "x": "48px",
          "y": "30%",
          "width": "200px",
          "font_size": "96pt",
          "font_family": "Source Sans 3",
          "font_weight": "900",
          "color": "#0D0D0D",
          "opacity": "0.15"
        },
        "section_title": {
          "x": "48px",
          "y": "40%",
          "width": "70%",
          "font_size": "40pt",
          "font_family": "Source Sans 3",
          "font_weight": "900",
          "color": "#0D0D0D",
          "text_transform": "uppercase"
        },
        "section_subtitle": {
          "x": "48px",
          "y": "62%",
          "width": "60%",
          "font_size": "18pt",
          "font_family": "Source Sans 3",
          "color": "#3A3A3A"
        }
      }
    },
    "content_slide": {
      "description": "Dark content slide with yellow-accented header region",
      "background": "#0D0D0D",
      "elements": {
        "title_accent_bar": {
          "type": "rectangle",
          "x": "0",
          "y": "0",
          "width": "6px",
          "height": "88px",
          "fill": "#FEC51D"
        },
        "slide_title": {
          "x": "28px",
          "y": "20px",
          "width": "calc(100% - 200px)",
          "height": "60px",
          "font_size": "28pt",
          "font_family": "Source Sans 3",
          "font_weight": "900",
          "color": "#FFFFFF",
          "text_transform": "uppercase"
        },
        "thin_rule": {
          "type": "line",
          "x": "28px",
          "y": "88px",
          "width": "calc(100% - 76px)",
          "height": "1px",
          "fill": "#3A3A3A"
        },
        "content_area": {
          "x": "48px",
          "y": "108px",
          "width": "calc(100% - 96px)",
          "height": "calc(100% - 168px)",
          "font_size": "16pt",
          "font_family": "Source Sans 3",
          "color": "#CCCCCC"
        },
        "footer": {
          "x": "48px",
          "y": "calc(100% - 44px)",
          "width": "calc(100% - 96px)",
          "height": "32px",
          "font_size": "11pt",
          "color": "#8A8A8A"
        }
      }
    },
    "two_column": {
      "description": "Split content, dark background, yellow accent on headings",
      "background": "#0D0D0D",
      "inherits_header_footer": true,
      "elements": {
        "left_column": {
          "x": "48px",
          "y": "108px",
          "width": "44%",
          "height": "calc(100% - 168px)"
        },
        "right_column": {
          "x": "calc(50% + 12px)",
          "y": "108px",
          "width": "calc(50% - 60px)",
          "height": "calc(100% - 168px)"
        }
      }
    },
    "image_full_bleed": {
      "description": "Edge-to-edge image with text overlay on dark scrim",
      "background": "#0D0D0D",
      "inherits_header_footer": false,
      "elements": {
        "image_layer": {
          "x": "0",
          "y": "0",
          "width": "100%",
          "height": "100%",
          "object_fit": "cover",
          "z_index": 1
        },
        "scrim": {
          "type": "rectangle",
          "x": "0",
          "y": "0",
          "width": "100%",
          "height": "100%",
          "fill": "#0D0D0D",
          "opacity": "0.6",
          "z_index": 2
        },
        "overlay_title": {
          "x": "48px",
          "y": "55%",
          "width": "70%",
          "font_size": "40pt",
          "font_family": "Source Sans 3",
          "color": "#FFFFFF",
          "text_transform": "uppercase",
          "z_index": 3
        },
        "overlay_subtitle": {
          "x": "48px",
          "y": "72%",
          "width": "60%",
          "font_size": "16pt",
          "font_family": "Source Sans 3",
          "color": "#CCCCCC",
          "z_index": 3
        }
      }
    },
    "stat_callout": {
      "description": "Large KPI numbers on dark cards \u2014 built for 2 or 3 stats",
      "background": "#0D0D0D",
      "inherits_header_footer": true,
      "elements": {
        "stat_grid": {
          "columns": 3,
          "column_gap": "24px",
          "x": "48px",
          "y": "108px",
          "width": "calc(100% - 96px)",
          "height": "calc(100% - 168px)"
        },
        "stat_card": {
          "background": "#1E1E1E",
          "padding": "32px",
          "border_left": "4px solid #FEC51D"
        },
        "stat_number": {
          "font_size": "64pt",
          "font_family": "Source Sans 3",
          "font_weight": "900",
          "color": "#FEC51D",
          "text_align": "left"
        },
        "stat_label": {
          "font_size": "14pt",
          "font_family": "Source Sans 3",
          "color": "#CCCCCC",
          "text_align": "left",
          "text_transform": "uppercase",
          "letter_spacing": "0.05em"
        }
      }
    },
    "closing_slide": {
      "description": "Bold closing \u2014 full dark, large centered call-to-action",
      "background": "#0D0D0D",
      "elements": {
        "yellow_bar_top": {
          "type": "rectangle",
          "x": "0",
          "y": "0",
          "width": "100%",
          "height": "6px",
          "fill": "#FEC51D"
        },
        "yellow_bar_bottom": {
          "type": "rectangle",
          "x": "0",
          "y": "calc(100% - 6px)",
          "width": "100%",
          "height": "6px",
          "fill": "#FEC51D"
        },
        "closing_text": {
          "x": "center",
          "y": "38%",
          "width": "70%",
          "text_align": "center",
          "font_size": "52pt",
          "font_family": "Source Sans 3",
          "color": "#FFFFFF",
          "text_transform": "uppercase"
        },
        "contact_info": {
          "x": "center",
          "y": "62%",
          "width": "55%",
          "text_align": "center",
          "font_size": "16pt",
          "font_family": "Source Sans 3",
          "color": "#8A8A8A"
        }
      }
    }
  }
}
